	<Folder>
		<name>Refineries (57)</name>
		<Placemark id="02F69AD5743E9267C470">
		<name>Kirishinefteorgsintez refinery (KINEF)</name>
		<description><![CDATA[<div>2nd refinery in Russia. Owned by Surgutneftegaz (major Russian oil company). 20-21 million tons/year refining capacity. 350.000 barrels per day. Represents roughly 6-7% of russia's total refining capacity. It produces : Gasoline, diesel, jet, fuel oil, bitumen, LPG, petrochemicals. Produces around 80 types of products.&nbsp;<br></div>]]></description>
		<LookAt>
			<longitude>32.04581125495781</longitude>
			<latitude>59.4955761427542</latitude>
			<altitude>16.99807707570836</altitude>
			<heading>0</heading>
			<tilt>0</tilt>
			<gx:fovy>35</gx:fovy>
			<range>12236.68886283296</range>
			<altitudeMode>absolute</altitudeMode>
		</LookAt>
		<styleUrl>#__managed_style_18DD88EC144081E8901C</styleUrl>
		<Point>
			<coordinates>32.05590868165775,59.48546610128013,29.77185591988754</coordinates>
		</Point>
	</Placemark>
		<Placemark id="0BAD6318AD3E92734D19">
		<name>Omsk refinery </name>
		<description><![CDATA[<div>Largest refinery in Russia. Owned by Gazprom Neft. Capacity around 21 million tons/year.&nbsp;<br></div>]]></description>
		<LookAt>
			<longitude>73.29601615501225</longitude>
			<latitude>55.07671198744744</latitude>
			<altitude>132.7924446205419</altitude>
			<heading>348.1667833384008</heading>
			<tilt>0</tilt>
			<gx:fovy>35</gx:fovy>
			<range>25845.59989350848</range>
			<altitudeMode>absolute</altitudeMode>
		</LookAt>
		<styleUrl>#__managed_style_18DD88EC144081E8901C</styleUrl>
		<Point>
			<coordinates>73.23182490608777,55.0636869098589,121.4742082917068</coordinates>
		</Point>
	</Placemark>
