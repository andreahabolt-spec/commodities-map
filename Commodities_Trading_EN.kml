		<Placemark id="01AF5FA0193FCEBB0A64">
			<name>Preem Gothenburg Refinery</name>
			<description><![CDATA[<ul style="list-style-type: disc;"><li style="margin: 0px; font-style: normal; font-variant-caps: normal; font-weight: normal; font-width: normal; font-size: 20px; line-height: normal; font-family: &quot;Times New Roman&quot;; font-size-adjust: none; font-kerning: auto; font-variant-alternates: normal; font-variant-ligatures: normal; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-position: normal; font-feature-settings: normal; font-optical-sizing: auto; font-variation-settings: normal;"><span style="font-weight: normal; font-style: normal; font-kerning: none;"><span class="font" style="font-family: &quot;Times New Roman&quot;;"><span class="size" style="font-size: 20px;">Located in the port of Gothenburg</span></span></span><br></li><li style="margin: 0px; font-style: normal; font-variant-caps: normal; font-weight: normal; font-width: normal; font-size: 20px; line-height: normal; font-family: &quot;Times New Roman&quot;; font-size-adjust: none; font-kerning: auto; font-variant-alternates: normal; font-variant-ligatures: normal; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-position: normal; font-feature-settings: normal; font-optical-sizing: auto; font-variation-settings: normal;"><span style="font-weight: normal; font-style: normal; font-kerning: none;"><span class="font" style="font-family: &quot;Times New Roman&quot;;"><span class="size" style="font-size: 20px;">Capacity around </span></span></span><span style="font-style: normal; font-kerning: none;"><b><span class="font" style="font-family: TimesNewRomanPS-BoldMT;"><span class="size" style="font-size: 20px;">125,000–130,000 barrels per day</span></span></b></span><br></li><li style="margin: 0px; font-style: normal; font-variant-caps: normal; font-weight: normal; font-width: normal; font-size: 20px; line-height: normal; font-family: &quot;Times New Roman&quot;; font-size-adjust: none; font-kerning: auto; font-variant-alternates: normal; font-variant-ligatures: normal; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-position: normal; font-feature-settings: normal; font-optical-sizing: auto; font-variation-settings: normal;"><span style="font-weight: normal; font-style: normal; font-kerning: none;"><span class="font" style="font-family: &quot;Times New Roman&quot;;"><span class="size" style="font-size: 20px;">Smaller than Lysekil</span></span></span><br></li><li style="margin: 0px; font-style: normal; font-variant-caps: normal; font-weight: normal; font-width: normal; font-size: 20px; line-height: normal; font-family: &quot;Times New Roman&quot;; font-size-adjust: none; font-kerning: auto; font-variant-alternates: normal; font-variant-ligatures: normal; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-position: normal; font-feature-settings: normal; font-optical-sizing: auto; font-variation-settings: normal;"><span style="font-weight: normal; font-style: normal; font-kerning: none;"><span class="font" style="font-family: &quot;Times New Roman&quot;;"><span class="size" style="font-size: 20px;">Produces transportation fuels and renewable fuels</span></span></span><br></li><li style="margin: 0px; font-style: normal; font-variant-caps: normal; font-weight: normal; font-width: normal; font-size: 20px; line-height: normal; font-family: &quot;Times New Roman&quot;; font-size-adjust: none; font-kerning: auto; font-variant-alternates: normal; font-variant-ligatures: normal; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-position: normal; font-feature-settings: normal; font-optical-sizing: auto; font-variation-settings: normal;"><span style="font-weight: normal; font-style: normal; font-kerning: none;"><span class="font" style="font-family: &quot;Times New Roman&quot;;"><span class="size" style="font-size: 20px;">Closely integrated with the industrial and port infrastructure of Gothenburg</span></span></span><br></li></ul><div><br></div>]]></description>
			<LookAt>
				<longitude>11.8323886</longitude>
				<latitude>57.70834980000001</latitude>
