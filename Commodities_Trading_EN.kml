				<gx:fovy>35</gx:fovy>
				<range>1646.893266842444</range>
				<altitudeMode>relativeToGround</altitudeMode>
			</LookAt>
			<styleUrl>#msn_icon?color=8d6e63&amp;id=2000&amp;scale=40</styleUrl>
			<Point>
				<altitudeMode>relativeToGround</altitudeMode>
