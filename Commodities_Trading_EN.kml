			<Point>
				<coordinates>29.15981090467059,-26.5512404127436,1588.166896837618</coordinates>
			</Point>
		</Placemark>
		<Placemark id="0D44AD4FC93EAF1FDA9B">
			<name>Tanjung Bin Storage Terminal</name>
			<description><![CDATA[<li>Massive <b>tank storage facilities</b><br></li><li>Deepwater <b>jetties for tankers</b><br></li><li>Blending and handling of refined oil products.<br></li><div>Mainly developed/operated by <span class="hover:entity-accent entity-underline inline cursor-pointer align-baseline"><span class="whitespace-normal">Dialog Group</span></span><br></div>]]></description>
