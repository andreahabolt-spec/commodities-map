: &quot;Times New Roman&quot;; font-size-adjust: none; font-kerning: auto; font-variant-alternates: normal; font-variant-ligatures: normal; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-position: normal; font-feature-settings: normal; font-optical-sizing: auto; font-variation-settings: normal;"><span style="font-style: normal; font-kerning: none;"><b><span class="font" style="font-family:TimesNewRomanPS-BoldMT"><span class="size" style="font-size:24px">⚙️ Caractéristiques principales</span></span></b></span><br></p><ul style="list-style-type: disc;"><li style="margin: 0px; font-style: normal; font-variant-caps: normal; font-weight: normal; font-width: normal; font-size: 20px; line-height: normal; font-family: &quot;Times New Roman&quot;; font-size-adjust: none; font-kerning: auto; font-variant-alternates: normal; font-variant-ligatures: normal; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-position: normal; font-feature-settings: normal; font-optical-sizing: auto; font-variation-settings: normal;"><span style="font-weight: normal; font-style: normal; font-kerning: none;"><span class="font" style="font-family:&quot;Times New Roman&quot;"><span class="size" style="font-size:20px">📏 Longueur totale : ~900 km (offshore + onshore)</span></span></span><br></li><li style="margin: 0px; font-style: normal; font-variant-caps: normal; font-weight: normal; font-width: normal; font-size: 20px; line-height: normal; font-family: &quot;Times New Roman&quot;; font-size-adjust: none; font-kerning: auto; font-variant-alternates: normal; font-variant-ligatures: normal; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-position: normal; font-feature-settings: normal; font-optical-sizing: auto; font-variation-settings: normal;"><span style="font-weight: normal; font-style: normal; font-kerning: none;"><span class="font" style="font-family:&quot;Times New Roman&quot;"><span class="size" style="font-size:20px">⚡ Capacité : ~10 milliards de m³ par an (10 bcm)</span></span></span><br></li><li style="margin: 0px; font-style: normal; font-variant-caps: normal; font-weight: normal; font-width: normal; font-size: 20px; line-height: normal; font-family: &quot;Times New Roman&quot;; font-size-adjust: none; font-kerning: auto; font-variant-alternates: normal; font-variant-ligatures: normal; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-position: normal; font-feature-settings: normal; font-optical-sizing: auto; font-variation-settings: normal;"><span style="font-weight: normal; font-style: normal; font-kerning: none;"><span class="font" style="font-family:&quot;Times New Roman&quot;"><span class="size" style="font-size:20px">🏗️ Mise en service : 2022</span></span></span><br></li><li style="margin: 0px; font-style: normal; font-variant-caps: normal; font-weight: normal; font-width: normal; font-size: 20px; line-height: normal; font-family: &quot;Times New Roman&quot;; font-size-adjust: none; font-kerning: auto; font-variant-alternates: normal; font-variant-ligatures: normal; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-position: normal; font-feature-settings: normal; font-optical-sizing: auto; font-variation-settings: normal;"><span style="font-weight: normal; font-style: normal; font-kerning: none;"><span class="font" style="font-family:&quot;Times New Roman&quot;"><span class="size" style="font-size:20px">🏢 Opérateurs :</span></span></span><br></li><ul style="list-style-type: circle;"><li style="margin: 0px; font-style: normal; font-variant-caps: normal; font-weight: normal; font-width: normal; font-size: 20px; line-height: normal; font-family: &quot;Times New Roman&quot;; font-size-adjust: none; font-kerning: auto; font-variant-alternates: normal; font-variant-ligatures: normal; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-position: normal; font-feature-settings: normal; font-optical-sizing: auto; font-variation-settings: normal;"><span style="font-weight: normal; font-style: normal; font-kerning: none;"><span class="font" style="font-family:&quot;Times New Roman&quot;"><span class="size" style="font-size:20px">Gaz-System (Pologne)</span></span></span><br></li><li style="margin: 0px; font-style: normal; font-variant-caps: normal; font-weight: normal; font-width: normal; font-size: 20px; line-height: normal; font-family: &quot;Times New Roman&quot;; font-size-adjust: none; font-kerning: auto; font-variant-alternates: normal; font-variant-ligatures: normal; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-position: normal; font-feature-settings: normal; font-optical-sizing: auto; font-variation-settings: normal;"><span style="font-weight: normal; font-style: normal; font-kerning: none;"><span class="font" style="font-family:&quot;Times New Roman&quot;"><span class="size" style="font-size:20px">Energinet (Danemark)</span></span></span><br></li></ul></ul><p style="margin: 0px; font-style: normal; font-variant-caps: normal; font-weight: normal; font-width: normal; font-size: 12px; line-height: normal; font-family: &quot;Times New Roman&quot;; font-size-adjust: none; font-kerning: auto; font-variant-alternates: normal; font-variant-ligatures: normal; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-position: normal; font-feature-settings: normal; font-optical-sizing: auto; font-variation-settings: normal; color: rgb(128, 128, 128); min-height: 13.8px;"><br></p><p style="margin: 0px 0px 14.9px; font-style: normal; font-variant-caps: normal; font-weight: normal; font-width: normal; font-size: 24px; line-height: normal; font-family: &quot;Times New Roman&quot;; font-size-adjust: none; font-kerning: auto; font-variant-alternates: normal; font-variant-ligatures: normal; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-position: normal; font-feature-settings: normal; font-optical-sizing: auto; font-variation-settings: normal;"><span style="font-style: normal; font-kerning: none;"><b><span class="font" style="font-family:TimesNewRomanPS-BoldMT"><span class="size" style="font-size:24px">🎯 À quoi ça sert ?</span></span></b></span><br></p><p style="margin: 0px 0px 12px; font-style: normal; font-variant-caps: normal; font-weight: normal; font-width: normal; font-size: 20px; line-height: normal; font-family: &quot;Times New Roman&quot;; font-size-adjust: none; font-kerning: auto; font-variant-alternates: normal; font-variant-ligatures: normal; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-position: normal; font-feature-settings: normal; font-optical-sizing: auto; font-variation-settings: normal;"><span style="font-weight: normal; font-style: normal; font-kerning: none;"><span class="font" style="font-family:&quot;Times New Roman&quot;"><span class="size" style="font-size:20px">👉 L’objectif principal est de :</span></span></span><br></p><ul style="list-style-type: disc;"><li style="margin: 0px; font-style: normal; font-variant-caps: normal; font-weight: normal; font-width: normal; font-size: 20px; line-height: normal; font-family: &quot;Times New Roman&quot;; font-size-adjust: none; font-kerning: auto; font-variant-alternates: normal; font-variant-ligatures: normal; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-position: normal; font-feature-settings: normal; font-optical-sizing: auto; font-variation-settings: normal;"><span style="font-style: normal; font-kerning: none;"><b><span class="font" style="font-family:TimesNewRomanPS-BoldMT"><span class="size" style="font-size:20px">diversifier les sources d’énergie</span></span></b></span><span style="font-weight: normal; font-style: normal; font-kerning: none;"><span class="font" style="font-family:&quot;Times New Roman&quot;"><span class="size" style="font-size:20px"> de la Pologne</span></span></span><br></li><li style="margin: 0px; font-style: normal; font-variant-caps: normal; font-weight: normal; font-width: normal; font-size: 20px; line-height: normal; font-family: &quot;Times New Roman&quot;; font-size-adjust: none; font-kerning: auto; font-variant-alternates: normal; font-variant-ligatures: normal; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-position: normal; font-feature-settings: normal; font-optical-sizing: auto; font-variation-settings: normal;"><span style="font-style: normal; font-kerning: none;"><b><span class="font" style="font-family:TimesNewRomanPS-BoldMT"><span class="size" style="font-size:20px">réduire la dépendance au gaz russe</span></span></b></span><br></li><li style="margin: 0px; font-style: normal; font-variant-caps: normal; font-weight: normal; font-width: normal; font-size: 20px; line-height: normal; font-family: &quot;Times New Roman&quot;; font-size-adjust: none; font-kerning: auto; font-variant-alternates: normal; font-variant-ligatures: normal; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-position: normal; font-feature-settings: normal; font-optical-sizing: auto; font-variation-settings: normal;"><span style="font-weight: normal; font-style: normal; font-kerning: none;"><span class="font" style="font-family:&quot;Times New Roman&quot;"><span class="size" style="font-size:20px">sécuriser l’approvisionnement en Europe centrale</span></span></span><br></li></ul><div><br></div>]]></description>
